// Auto-generated by KooSolderEvolver v{{ version }}
// Solder joint: {{ joint_name }}

{% if evolver_version %}evolver_version "{{ evolver_version }}"{% endif %}

// Physical constants ({{ unit_system_name }} units)
parameter S_TENSION = {{ tension }}     // {{ tension_unit }}
parameter SOLDER_DENSITY = {{ density }}  // {{ density_unit }}
gravity_constant {{ gravity }}          // {{ length_unit }}/s^2

// Geometric parameters
parameter radius = {{ radius }}          // pad radius, {{ length_unit }}
{% for p in extra_params %}
parameter {{ p.name }} = {{ p.value }}   // {{ p.comment }}
{% endfor %}

{% for c in constraints %}
// {{ c.comment }}
constraint {{ c.id }}
formula: {{ c.formula }}
{% if c.energy %}
energy:
e1: {{ c.energy[0] }}
e2: {{ c.energy[1] }}
e3: {{ c.energy[2] }}
{% endif %}
{% if c.content %}
content:
c1: {{ c.content[0] }}
c2: {{ c.content[1] }}
c3: {{ c.content[2] }}
{% endif %}

{% endfor %}
{% for b in boundaries %}
// {{ b.comment }}
boundary {{ b.id }} {{ b.params }}
{{ b.definition }}
{% if b.energy %}
energy:
e1: {{ b.energy[0] }}
e2: {{ b.energy[1] }}
e3: {{ b.energy[2] }}
{% endif %}
{% if b.content %}
content:
c1: {{ b.content[0] }}
c2: {{ b.content[1] }}
c3: {{ b.content[2] }}
{% endif %}

{% endfor %}
vertices
{% for v in vertices %}
{{ v.id }}  {{ v.x }}  {{ v.y }}  {{ v.z }}{{ '  constraints ' ~ (v.constraints | join(' ')) if v.constraints }}{{ '  boundary ' ~ v.boundary if v.boundary }}{{ '  fixed' if v.fixed }}{{ v.extras }}
{% endfor %}

edges
{% for e in edges %}
{{ e.id }}  {{ e.v1 }}  {{ e.v2 }}{{ '  constraints ' ~ (e.constraints | join(' ')) if e.constraints }}{{ '  boundary ' ~ e.boundary if e.boundary }}{{ '  fixed' if e.fixed }}
{% endfor %}

faces
{% for f in faces %}
{{ f.id }}  {{ f.edges | join(' ') }}{{ '  tension S_TENSION' if f.tension is not none }}{{ '  fixed' if f.fixed }}{{ '  color ' ~ f.color if f.color }}{{ '  no_refine' if f.no_refine }}
{% endfor %}

bodies
{% for b in bodies %}
{{ b.id }}  {{ b.faces | join(' ') }}{{ '  volume ' ~ b.volume if b.volume }}{{ '  density SOLDER_DENSITY' if b.density }}
{% endfor %}

read

{{ evolution_script }}
