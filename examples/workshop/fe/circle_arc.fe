// circle_arc.fe
// Single circle of area 1 made of four arcs.
// Demonstration of circular arc mode.

string
space_dimension 2

area_method_name "circular_arc_area"
length_method_name "circular_arc_length"

Vertices
1  -1 -1 
2  1 -1
3  1 1
4  -1 1

Edges
1  1 2
2  2 3
3  3 4
4  4 1

Faces
1  1 2 3 4 

Bodies
1  1  volume pi

